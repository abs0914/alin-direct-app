{
  "expo": {
    "name": "ALiN Move",
    "slug": "alin-move-customer",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "alinmove",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f5a524"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.alinmove.customer",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "ALiN Move needs your location to set pickup addresses and track your deliveries."
      }
    },
    "android": {
      "package": "com.alinmove.customer",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#f5a524"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "ALiN Move needs your location to set pickup addresses."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "ALiN Move needs photo access for package photos."
        }
      ],
      "expo-secure-store"
    ]
  }
}
