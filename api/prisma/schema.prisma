// Prisma schema for ALiN Cargo Express API
// Mirrors the existing Laravel/MySQL database exactly so the parallel run shares the same DB.
// Generator produces a TypeScript client used by the Fastify API.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["public"]
}

// ─── RBAC ────────────────────────────────────────────────────────────────────

model Permission {
  id        BigInt   @id @default(autoincrement())
  name      String
  guardName String   @map("guard_name")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  roles            RoleHasPermission[]
  modelPermissions ModelHasPermission[]

  @@map("permissions")
  @@schema("public")
}

model Role {
  id        BigInt   @id @default(autoincrement())
  name      String
  guardName String   @map("guard_name")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  permissions RoleHasPermission[]
  modelRoles  ModelHasRole[]

  @@map("roles")
  @@schema("public")
}

model ModelHasPermission {
  permissionId BigInt @map("permission_id")
  modelType    String @map("model_type")
  modelId      BigInt @map("model_id")

  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([permissionId, modelId, modelType])
  @@map("model_has_permissions")
  @@schema("public")
}

model ModelHasRole {
  roleId    BigInt @map("role_id")
  modelType String @map("model_type")
  modelId   BigInt @map("model_id")

  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, modelId, modelType])
  @@map("model_has_roles")
  @@schema("public")
}

model RoleHasPermission {
  permissionId BigInt @map("permission_id")
  roleId       BigInt @map("role_id")

  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([permissionId, roleId])
  @@map("role_has_permissions")
  @@schema("public")
}

// ─── CORE ENTITIES ───────────────────────────────────────────────────────────

model Branch {
  id              BigInt    @id @default(autoincrement())
  name            String
  code            String    @unique
  type            String    @default("branch") // hub, branch, satellite
  address         String?   @db.Text
  city            String?
  province        String?
  lat             Decimal?  @db.Decimal(10, 7)
  lng             Decimal?  @db.Decimal(10, 7)
  serviceRadiusKm Decimal   @default(10.00) @map("service_radius_km") @db.Decimal(8, 2)
  phone           String?
  email           String?
  isActive        Boolean   @default(true) @map("is_active")
  operatingHours  Json?     @map("operating_hours")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  users                      User[]
  riders                     Rider[]
  deliveryJobs               DeliveryJob[]
  salesTransactions          SalesTransaction[]
  expenses                   Expense[]
  dailyClosings              DailyClosing[]
  attendances                Attendance[]
  emergencyAlerts            EmergencyAlert[]
  supportConversations       SupportConversation[]
  supportCases               SupportCase[]
  stPeterApplications        StPeterApplication[]
  personalAccidentInsurances PersonalAccidentInsurance[]

  @@map("branches")
  @@schema("public")
}

model User {
  id              BigInt    @id @default(autoincrement())
  supabaseId      String?   @unique @map("supabase_id") @db.VarChar(36)
  name            String
  phone           String?   @unique
  email           String?   @unique
  emailVerifiedAt DateTime? @map("email_verified_at")
  phoneVerifiedAt DateTime? @map("phone_verified_at")
  password        String?
  userType        String    @default("customer") @map("user_type") // admin, branch_manager, dispatcher, rider, customer
  isActive        Boolean   @default(true) @map("is_active")
  branchId        BigInt?   @map("branch_id")
  avatarUrl       String?   @map("avatar_url")
  rememberToken   String?   @map("remember_token") @db.VarChar(100)
  expoPushToken   String?   @map("expo_push_token")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  branch Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  rider    Rider?
  customer Customer?

  // Jobs
  senderJobs        DeliveryJob[] @relation("SenderJobs")
  createdJobs       DeliveryJob[] @relation("CreatedByJobs")
  codSettledJobs    DeliveryJob[] @relation("CodSettledBy")
  kycVerifiedRiders Rider[]       @relation("KycVerifiedBy")

  // Finance
  ledgerEntries   LedgerEntry[]
  payments        Payment[]
  payoutApprovals PayoutRequest[] @relation("ApprovedBy")

  // Daily closings
  dailyClosings DailyClosing[]

  // Attendance
  attendances Attendance[]

  // Support
  supportConversationsUser  SupportConversation[] @relation("ConversationUser")
  supportConversationsAgent SupportConversation[] @relation("OwnerAgent")
  supportMessages           SupportMessage[]
  supportCasesAssigned      SupportCase[]         @relation("AssignedAgent")
  supportCasesResolved      SupportCase[]         @relation("ResolvedBy")

  // Knowledge articles
  knowledgeArticles KnowledgeArticle[]

  // Insurance
  stPeterApplications        StPeterApplication[]
  personalAccidentInsurances PersonalAccidentInsurance[]
  salesTransactions          SalesTransaction[]
  Expense                    Expense[]

  @@map("users")
  @@schema("public")
}

model Rider {
  id           BigInt    @id @default(autoincrement())
  userId       BigInt    @unique @map("user_id")
  branchId     BigInt?   @map("branch_id")
  vehicleType  String    @default("motorcycle") @map("vehicle_type")
  plateNumber  String?   @map("plate_number")
  vehicleBrand String?   @map("vehicle_brand")
  vehicleModel String?   @map("vehicle_model")
  vehicleColor String?   @map("vehicle_color")
  status       String    @default("pending") // pending, approved, suspended, rejected, blacklisted
  availability String    @default("offline") // offline, online, on_job
  currentLat   Decimal?  @map("current_lat") @db.Decimal(10, 7)
  currentLng   Decimal?  @map("current_lng") @db.Decimal(10, 7)
  lastSeenAt   DateTime? @map("last_seen_at")

  licenseUrl      String?   @map("license_url")
  orCrUrl         String?   @map("or_cr_url")
  nbiClearanceUrl String?   @map("nbi_clearance_url")
  selfieUrl       String?   @map("selfie_url")
  kycVerifiedAt   DateTime? @map("kyc_verified_at")
  kycVerifiedBy   BigInt?   @map("kyc_verified_by")

  termsAccepted   Boolean   @default(false) @map("terms_accepted")
  termsAcceptedAt DateTime? @map("terms_accepted_at")

  mayaWalletId String? @map("maya_wallet_id")
  mayaPhone    String? @map("maya_phone")

  rating          Decimal @default(0.00) @db.Decimal(3, 2)
  totalDeliveries Int     @default(0) @map("total_deliveries")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch      Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  kycVerifier User?   @relation("KycVerifiedBy", fields: [kycVerifiedBy], references: [id], onDelete: SetNull)

  deliveryJobs       DeliveryJob[]
  jobOffers          JobOffer[]
  payoutRequests     PayoutRequest[]
  emergencyAlerts    EmergencyAlert[]
  emergencyResponses EmergencyAlert[] @relation("RespondedByRider")

  @@index([branchId, status, availability])
  @@index([vehicleType, availability])
  @@map("riders")
  @@schema("public")
}

model Customer {
  id             BigInt    @id @default(autoincrement())
  userId         BigInt    @unique @map("user_id")
  companyName    String?   @map("company_name")
  defaultAddress String?   @map("default_address") @db.Text
  defaultLat     Decimal?  @map("default_lat") @db.Decimal(10, 7)
  defaultLng     Decimal?  @map("default_lng") @db.Decimal(10, 7)
  mayaCustomerId String?   @map("maya_customer_id")
  totalBookings  Int       @default(0) @map("total_bookings")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  personalAccidentInsurances PersonalAccidentInsurance[]

  @@map("customers")
  @@schema("public")
}

// ─── DELIVERY ────────────────────────────────────────────────────────────────

model DeliveryJob {
  id           BigInt  @id @default(autoincrement())
  trackingUuid String  @unique @map("tracking_uuid") @db.VarChar(36)
  senderId     BigInt? @map("sender_id")
  riderId      BigInt? @map("rider_id")
  branchId     BigInt? @map("branch_id")
  createdBy    BigInt? @map("created_by")

  status      String  @default("pending")
  isEmergency Boolean @default(false) @map("is_emergency")
  vehicleType String  @default("motorcycle") @map("vehicle_type")

  pickupContactName  String   @map("pickup_contact_name")
  pickupContactPhone String   @map("pickup_contact_phone")
  pickupAddress      String   @map("pickup_address") @db.Text
  pickupLat          Decimal? @map("pickup_lat") @db.Decimal(10, 7)
  pickupLng          Decimal? @map("pickup_lng") @db.Decimal(10, 7)
  pickupNotes        String?  @map("pickup_notes") @db.Text

  dropoffContactName  String   @map("dropoff_contact_name")
  dropoffContactPhone String   @map("dropoff_contact_phone")
  dropoffAddress      String   @map("dropoff_address") @db.Text
  dropoffLat          Decimal? @map("dropoff_lat") @db.Decimal(10, 7)
  dropoffLng          Decimal? @map("dropoff_lng") @db.Decimal(10, 7)
  dropoffNotes        String?  @map("dropoff_notes") @db.Text

  packageDescription String?  @map("package_description")
  packageSize        String   @default("small") @map("package_size")
  packageWeightKg    Decimal? @map("package_weight_kg") @db.Decimal(8, 2)
  boxType            String   @default("own_box") @map("box_type")

  distanceKm         Decimal? @map("distance_km") @db.Decimal(8, 2)
  baseFare           Decimal  @default(0) @map("base_fare") @db.Decimal(10, 2)
  distanceFare       Decimal  @default(0) @map("distance_fare") @db.Decimal(10, 2)
  surgeMultiplier    Decimal  @default(1.00) @map("surge_multiplier") @db.Decimal(4, 2)
  totalPrice         Decimal  @default(0) @map("total_price") @db.Decimal(10, 2)
  riderEarnings      Decimal  @default(0) @map("rider_earnings") @db.Decimal(10, 2)
  platformCommission Decimal  @default(0) @map("platform_commission") @db.Decimal(10, 2)

  paymentMethod String    @default("cod") @map("payment_method")
  paymentStatus String    @default("pending") @map("payment_status")
  codCollected  Boolean   @default(false) @map("cod_collected")
  codSettled    Boolean   @default(false) @map("cod_settled")
  codSettledAt  DateTime? @map("cod_settled_at")
  codSettledBy  BigInt?   @map("cod_settled_by")

  failureReason String? @map("failure_reason")
  failureNotes  String? @map("failure_notes") @db.Text

  acceptedAt  DateTime? @map("accepted_at")
  pickedUpAt  DateTime? @map("picked_up_at")
  deliveredAt DateTime? @map("delivered_at")
  failedAt    DateTime? @map("failed_at")
  cancelledAt DateTime? @map("cancelled_at")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  sender     User?   @relation("SenderJobs", fields: [senderId], references: [id], onDelete: SetNull)
  rider      Rider?  @relation(fields: [riderId], references: [id], onDelete: SetNull)
  branch     Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  creator    User?   @relation("CreatedByJobs", fields: [createdBy], references: [id], onDelete: SetNull)
  codSettler User?   @relation("CodSettledBy", fields: [codSettledBy], references: [id], onDelete: SetNull)

  jobOffers            JobOffer[]
  proofOfDelivery      ProofOfDelivery?
  payments             Payment[]
  salesTransactions    SalesTransaction[]
  supportConversations SupportConversation[]
  supportCases         SupportCase[]
  emergencyAlerts      EmergencyAlert[]

  @@index([branchId, status])
  @@index([riderId, status])
  @@index([senderId, status])
  @@index([status, createdAt])
  @@index([paymentStatus, codCollected, codSettled])
  @@map("delivery_jobs")
  @@schema("public")
}

model JobOffer {
  id          BigInt    @id @default(autoincrement())
  jobId       BigInt    @map("job_id")
  riderId     BigInt    @map("rider_id")
  status      String    @default("pending") // pending, accepted, rejected, expired, cancelled
  expiresAt   DateTime  @map("expires_at")
  respondedAt DateTime? @map("responded_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  job   DeliveryJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  rider Rider       @relation(fields: [riderId], references: [id], onDelete: Cascade)

  @@unique([jobId, riderId])
  @@index([riderId, status])
  @@map("job_offers")
  @@schema("public")
}

model ProofOfDelivery {
  id            BigInt   @id @default(autoincrement())
  jobId         BigInt   @unique @map("job_id")
  photoUrl      String   @map("photo_url")
  signatureUrl  String?  @map("signature_url")
  recipientName String   @map("recipient_name")
  relationship  String?
  deliveryLat   Decimal? @map("delivery_lat") @db.Decimal(10, 7)
  deliveryLng   Decimal? @map("delivery_lng") @db.Decimal(10, 7)
  notes         String?  @db.Text
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  job DeliveryJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("proof_of_deliveries")
  @@schema("public")
}

// ─── FINANCE ─────────────────────────────────────────────────────────────────

model LedgerEntry {
  id             BigInt   @id @default(autoincrement())
  userId         BigInt   @map("user_id")
  type           String // earning, commission, payout, cod_collection, cod_settlement, refund, adjustment, bonus
  amount         Decimal  @db.Decimal(12, 2)
  balanceAfter   Decimal  @map("balance_after") @db.Decimal(12, 2)
  referenceType  String?  @map("reference_type")
  referenceId    BigInt?  @map("reference_id")
  status         String   @default("completed") // pending, completed, reversed, held
  description    String?  @db.Text
  idempotencyKey String?  @unique @map("idempotency_key")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([referenceType, referenceId])
  @@index([status, createdAt])
  @@map("ledger_entries")
  @@schema("public")
}

model Payment {
  id             BigInt   @id @default(autoincrement())
  jobId          BigInt?  @map("job_id")
  userId         BigInt?  @map("user_id")
  provider       String   @default("maya") // maya, cod, manual
  type           String   @default("checkout") // checkout, disbursement, refund
  referenceNo    String?  @unique @map("reference_no")
  mayaCheckoutId String?  @map("maya_checkout_id")
  mayaPaymentId  String?  @map("maya_payment_id")
  amount         Decimal  @db.Decimal(12, 2)
  currency       String   @default("PHP") @db.VarChar(3)
  status         String   @default("pending") // pending, processing, completed, failed, refunded, expired
  payloadJson    Json?    @map("payload_json")
  webhookPayload Json?    @map("webhook_payload")
  idempotencyKey String?  @unique @map("idempotency_key")
  failureReason  String?  @map("failure_reason") @db.Text
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  job  DeliveryJob? @relation(fields: [jobId], references: [id], onDelete: SetNull)
  user User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([jobId, status])
  @@index([userId, type, status])
  @@index([provider, status])
  @@map("payments")
  @@schema("public")
}

model PayoutRequest {
  id                 BigInt    @id @default(autoincrement())
  riderId            BigInt    @map("rider_id")
  amount             Decimal   @db.Decimal(12, 2)
  status             String    @default("pending") // pending, approved, processing, completed, rejected, failed
  approvedBy         BigInt?   @map("approved_by")
  approvedAt         DateTime? @map("approved_at")
  mayaDisbursementId String?   @map("maya_disbursement_id")
  rejectionReason    String?   @map("rejection_reason") @db.Text
  notes              String?   @db.Text
  idempotencyKey     String?   @unique @map("idempotency_key")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  rider    Rider @relation(fields: [riderId], references: [id], onDelete: Cascade)
  approver User? @relation("ApprovedBy", fields: [approvedBy], references: [id], onDelete: SetNull)

  @@index([riderId, status])
  @@index([status, createdAt])
  @@map("payout_requests")
  @@schema("public")
}

// ─── BRANCH OPS ──────────────────────────────────────────────────────────────

model ServiceCategory {
  id        BigInt   @id @default(autoincrement())
  name      String
  slug      String   @unique
  icon      String?
  color     String?
  logo      String?
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  services Service[]

  @@map("service_categories")
  @@schema("public")
}

model Service {
  id                BigInt   @id @default(autoincrement())
  serviceCategoryId BigInt   @map("service_category_id")
  name              String
  slug              String   @unique
  sortOrder         Int      @default(0) @map("sort_order")
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  serviceCategory   ServiceCategory    @relation(fields: [serviceCategoryId], references: [id], onDelete: Cascade)
  salesTransactions SalesTransaction[]

  @@map("services")
  @@schema("public")
}

model SalesTransaction {
  id              BigInt  @id @default(autoincrement())
  branchId        BigInt  @map("branch_id")
  serviceId       BigInt  @map("service_id")
  amount          Decimal @db.Decimal(12, 2)
  paymentMethod   String  @map("payment_method")
  referenceNumber String? @map("reference_number")
  customerName    String? @map("customer_name")
  createdById     BigInt  @map("created_by")
  dailyClosingId  BigInt? @map("daily_closing_id")
  notes           String? @db.Text
  boxType         String? @map("box_type")
  packageSize     String? @map("package_size")
  serviceType     String? @map("service_type")

  // Insurance links
  stPeterApplicationId        BigInt? @map("st_peter_application_id")
  personalAccidentInsuranceId BigInt? @map("personal_accident_insurance_id")

  // Optional delivery job link
  deliveryJobId BigInt? @map("delivery_job_id")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  branch                    Branch                     @relation(fields: [branchId], references: [id], onDelete: Cascade)
  service                   Service                    @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  createdBy                 User                       @relation(fields: [createdById], references: [id], onDelete: Cascade)
  dailyClosing              DailyClosing?              @relation(fields: [dailyClosingId], references: [id], onDelete: SetNull)
  deliveryJob               DeliveryJob?               @relation(fields: [deliveryJobId], references: [id], onDelete: SetNull)
  stPeterApplication        StPeterApplication?        @relation(fields: [stPeterApplicationId], references: [id], onDelete: SetNull)
  personalAccidentInsurance PersonalAccidentInsurance? @relation(fields: [personalAccidentInsuranceId], references: [id], onDelete: SetNull)

  @@index([branchId, createdAt])
  @@index([dailyClosingId])
  @@map("sales_transactions")
  @@schema("public")
}

model Expense {
  id              BigInt    @id @default(autoincrement())
  branchId        BigInt    @map("branch_id")
  category        String // utilities, supplies, salaries, rent, maintenance, other
  vendorName      String?   @map("vendor_name")
  amount          Decimal   @db.Decimal(12, 2)
  paymentMethod   String    @map("payment_method")
  referenceNumber String?   @map("reference_number")
  description     String?   @db.Text
  receiptPath     String?   @map("receipt_path")
  createdById     BigInt    @map("created_by")
  dailyClosingId  BigInt?   @map("daily_closing_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  branch       Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdBy    User          @relation(fields: [createdById], references: [id], onDelete: Cascade)
  dailyClosing DailyClosing? @relation(fields: [dailyClosingId], references: [id], onDelete: SetNull)

  @@index([branchId, createdAt])
  @@index([dailyClosingId])
  @@map("expenses")
  @@schema("public")
}

model DailyClosing {
  id                   BigInt    @id @default(autoincrement())
  branchId             BigInt    @map("branch_id")
  businessDate         DateTime  @map("business_date") @db.Date
  openingBalance       Decimal   @default(0) @map("opening_balance") @db.Decimal(12, 2)
  totalCashSales       Decimal   @default(0) @map("total_cash_sales") @db.Decimal(12, 2)
  totalDigitalSales    Decimal   @default(0) @map("total_digital_sales") @db.Decimal(12, 2)
  totalCashExpenses    Decimal   @default(0) @map("total_cash_expenses") @db.Decimal(12, 2)
  totalDigitalExpenses Decimal   @default(0) @map("total_digital_expenses") @db.Decimal(12, 2)
  expectedCash         Decimal   @default(0) @map("expected_cash") @db.Decimal(12, 2)
  actualCash           Decimal?  @map("actual_cash") @db.Decimal(12, 2)
  variance             Decimal?  @db.Decimal(12, 2)
  managerNotes         String?   @map("manager_notes") @db.Text
  closedById           BigInt?   @map("closed_by")
  closedAt             DateTime? @map("closed_at")
  status               String    @default("open") // open, closed
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  closedBy User?  @relation(fields: [closedById], references: [id], onDelete: SetNull)

  salesTransactions SalesTransaction[]
  expenses          Expense[]

  @@unique([branchId, businessDate])
  @@index([branchId, status])
  @@map("daily_closings")
  @@schema("public")
}

model Attendance {
  id                BigInt    @id @default(autoincrement())
  userId            BigInt    @map("user_id")
  branchId          BigInt    @map("branch_id")
  attendanceDate    DateTime  @map("attendance_date") @db.Date
  checkInAt         DateTime  @map("check_in_at")
  checkOutAt        DateTime? @map("check_out_at")
  checkInImagePath  String    @map("check_in_image_path")
  checkOutImagePath String?   @map("check_out_image_path")
  status            String    @default("checked_in")
  notes             String?   @db.Text
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([userId, attendanceDate])
  @@index([branchId, attendanceDate])
  @@index([userId, status])
  @@map("attendances")
  @@schema("public")
}

// ─── EMERGENCY ───────────────────────────────────────────────────────────────

model EmergencyAlert {
  id                 BigInt    @id @default(autoincrement())
  riderId            BigInt    @map("rider_id")
  branchId           BigInt?   @map("branch_id")
  lat                Decimal?  @db.Decimal(10, 7)
  lng                Decimal?  @db.Decimal(10, 7)
  status             String    @default("active") // active, responding, resolved, cancelled
  emergencyJobId     BigInt?   @map("emergency_job_id")
  respondedByRiderId BigInt?   @map("responded_by_rider_id")
  notes              String?   @db.Text
  resolvedAt         DateTime? @map("resolved_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  rider            Rider        @relation(fields: [riderId], references: [id], onDelete: Cascade)
  branch           Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)
  emergencyJob     DeliveryJob? @relation(fields: [emergencyJobId], references: [id], onDelete: SetNull)
  respondedByRider Rider?       @relation("RespondedByRider", fields: [respondedByRiderId], references: [id], onDelete: SetNull)

  @@index([branchId, status])
  @@index([riderId, status])
  @@index([status, createdAt])
  @@map("emergency_alerts")
  @@schema("public")
}

// ─── SUPPORT ─────────────────────────────────────────────────────────────────

model KnowledgeArticle {
  id          BigInt   @id @default(autoincrement())
  title       String
  category    String // tracking, pricing, policy, account, complaint
  content     String   @db.Text
  tags        Json?
  isActive    Boolean  @default(true) @map("is_active")
  createdById BigInt?  @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  createdBy User? @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([category, isActive])
  @@map("knowledge_articles")
  @@schema("public")
}

model SupportConversation {
  id              BigInt    @id @default(autoincrement())
  userId          BigInt    @map("user_id")
  channel         String    @default("app") // app, messenger, web
  status          String    @default("open") // open, bot_handling, pending_agent, agent_active, resolved, closed
  ownerType       String?   @map("owner_type") // bot, branch, hq
  ownerAgentId    BigInt?   @map("owner_agent_id")
  branchId        BigInt?   @map("branch_id")
  deliveryJobId   BigInt?   @map("delivery_job_id")
  intent          String?
  aiConfidence    Int?      @map("ai_confidence")@db.SmallInt
  sentimentScore  Int?      @map("sentiment_score")@db.SmallInt
  escalationFlag  Boolean   @default(false) @map("escalation_flag")
  firstResponseAt DateTime? @map("first_response_at")
  resolvedAt      DateTime? @map("resolved_at")
  lastMessageAt   DateTime? @map("last_message_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  user        User         @relation("ConversationUser", fields: [userId], references: [id], onDelete: Cascade)
  ownerAgent  User?        @relation("OwnerAgent", fields: [ownerAgentId], references: [id], onDelete: SetNull)
  branch      Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)
  deliveryJob DeliveryJob? @relation(fields: [deliveryJobId], references: [id], onDelete: SetNull)

  messages SupportMessage[]
  cases    SupportCase[]

  @@index([userId, status])
  @@index([branchId, status])
  @@index([status, escalationFlag])
  @@index([lastMessageAt])
  @@map("support_conversations")
  @@schema("public")
}

model SupportMessage {
  id             BigInt    @id @default(autoincrement())
  conversationId BigInt    @map("conversation_id")
  senderType     String    @map("sender_type") // customer, rider, agent, bot
  senderId       BigInt?   @map("sender_id")
  body           String    @db.Text
  messageType    String    @default("text") @map("message_type") // text, image, status_update, handoff_note, internal_note
  attachmentUrl  String?   @map("attachment_url")
  aiConfidence   Int?      @map("ai_confidence")@db.SmallInt
  aiMetadata     Json?     @map("ai_metadata")
  readAt         DateTime? @map("read_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  conversation SupportConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User?               @relation(fields: [senderId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
  @@index([senderType, conversationId])
  @@map("support_messages")
  @@schema("public")
}

model SupportCase {
  id              BigInt    @id @default(autoincrement())
  conversationId  BigInt    @map("conversation_id")
  deliveryJobId   BigInt?   @map("delivery_job_id")
  branchId        BigInt?   @map("branch_id")
  category        String // tracking, pricing, complaint, damage, payment, refund, account, other
  subcategory     String?
  priority        String    @default("normal") // low, normal, high, critical
  assignedTeam    String    @default("bot") @map("assigned_team") // bot, branch, hq, back_office
  assignedAgentId BigInt?   @map("assigned_agent_id")
  slaDueAt        DateTime? @map("sla_due_at")
  status          String    @default("open") // open, in_progress, pending_customer, resolved, closed
  resolutionCode  String?   @map("resolution_code")
  resolutionNotes String?   @map("resolution_notes") @db.Text
  resolvedAt      DateTime? @map("resolved_at")
  resolvedById    BigInt?   @map("resolved_by")
  aiSummary       String?   @map("ai_summary") @db.Text
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  conversation  SupportConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  deliveryJob   DeliveryJob?        @relation(fields: [deliveryJobId], references: [id], onDelete: SetNull)
  branch        Branch?             @relation(fields: [branchId], references: [id], onDelete: SetNull)
  assignedAgent User?               @relation("AssignedAgent", fields: [assignedAgentId], references: [id], onDelete: SetNull)
  resolvedBy    User?               @relation("ResolvedBy", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([branchId, status])
  @@index([assignedTeam, status])
  @@index([priority, status, slaDueAt])
  @@map("support_cases")
  @@schema("public")
}

// ─── INSURANCE ────────────────────────────────────────────────────────────────

model StPeterApplication {
  id            BigInt   @id @default(autoincrement())
  fullName      String   @map("full_name")
  nationality   String
  mobile        String
  email         String
  dateOfBirth   DateTime @map("date_of_birth") @db.Date
  address       String   @db.Text
  beneficiaries Json?
  branchId      BigInt   @map("branch_id")
  createdById   BigInt   @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  branch    Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdBy User   @relation(fields: [createdById], references: [id], onDelete: Cascade)

  salesTransactions SalesTransaction[]

  @@map("st_peter_applications")
  @@schema("public")
}

model PersonalAccidentInsurance {
  id            BigInt   @id @default(autoincrement())
  policyNumber  String   @unique @map("policy_number")
  customerId    BigInt   @map("customer_id")
  fullName      String   @map("full_name")
  nationality   String
  mobile        String
  email         String
  dateOfBirth   DateTime @map("date_of_birth") @db.Date
  address       String   @db.Text
  beneficiaries Json?
  validFrom     DateTime @map("valid_from") @db.Date
  validUntil    DateTime @map("valid_until") @db.Date
  status        String   @default("active") // active, expired, cancelled
  branchId      BigInt   @map("branch_id")
  createdById   BigInt   @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  customer  Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  createdBy User     @relation(fields: [createdById], references: [id], onDelete: Cascade)

  salesTransactions SalesTransaction[]

  @@map("personal_accident_insurances")
  @@schema("public")
}

// ─── UTILITY TABLES ──────────────────────────────────────────────────────────

model OtpCode {
  id         BigInt    @id @default(autoincrement())
  phone      String
  code       String
  purpose    String    @default("login") // login, pickup_verification, registration
  expiresAt  DateTime  @map("expires_at")
  verifiedAt DateTime? @map("verified_at")
  attempts   Int       @default(0)
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@index([phone, code, purpose])
  @@map("otp_codes")
  @@schema("public")
}

model SystemConfig {
  id          BigInt   @id @default(autoincrement())
  key         String   @unique
  value       String   @db.Text
  group       String   @default("general")
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("system_configs")
  @@schema("public")
}
