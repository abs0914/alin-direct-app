# ──────────────────────────────────────────────────────────────
# ALiN Direct API — environment variable template
# Copy this file to .env and fill in your own values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────

# Supabase PostgreSQL — Transaction-mode pooler (port 6543)
# Used by the Fastify API at runtime (pgbouncer=true required).
# Special chars in password must be URL-encoded: # → %23, @ → %40
DATABASE_URL="postgresql://postgres.<project-ref>:<url-encoded-password>@aws-1-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Supabase PostgreSQL — Session-mode pooler (port 5432)
# Used by Prisma for `db push` / `migrate deploy` (supports DDL).
DIRECT_URL="postgresql://postgres.<project-ref>:<url-encoded-password>@aws-1-<region>.pooler.supabase.com:5432/postgres"

# Supabase project settings (Settings → API)
SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_JWT_SECRET="<your-jwt-secret>"

# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# Claude AI — used by the support AI service when AI_DRIVER=claude
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-..."
CLAUDE_MODEL="claude-sonnet-4-6"

# Ollama — local LLM fallback when AI_DRIVER=ollama
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3"

# AI driver selection: claude | ollama
AI_DRIVER=ollama
